# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scriptsync

# Auth
ACCESS_TOKEN_SECRET=change-me-access-secret-min-32-chars
REFRESH_TOKEN_SECRET=change-me-refresh-secret-min-32-chars

# Storage (Cloudflare R2) — leave blank to use local filesystem fallback
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=scriptsync-clips
R2_PUBLIC_URL=

# Local storage fallback path (used when R2 credentials are not set)
LOCAL_STORAGE_PATH=./storage

# Redis (for Bull queue)
REDIS_URL=redis://localhost:6379

# Email (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@scriptsyncpro.com

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Whisper (server-side)
WHISPER_BINARY_PATH=/usr/local/bin/whisper
WHISPER_MODEL_PATH=./models/ggml-base.en.bin

# Frontend URLs (for CORS and email links)
PORTAL_URL=http://localhost:5173
PLUGIN_ORIGIN=http://localhost:8080
